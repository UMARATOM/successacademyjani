<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Success Academy - Students</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="app-container">
        <header class="header-bar">
            <h2>Success Academy</h2>
            <div class="user-info">Logged in: <strong><%= user.username %></strong> (<%= user.role %>) | <a href="/logout">Logout</a></div>
        </header>

        <nav class="navigation-tabs">
            <a href="/dashboard">Dashboard</a>
            <a href="/students" class="active">Manage Students</a>
            <% if (user.role === 'admin') { %>
                <a href="/teachers">Manage Staff</a>
            <% } %>
            <a href="/grades">Gradebook</a>
        </nav>

        <main class="content-body">
            <div class="content-header">
                <h3>Registered Students</h3>
                <div>
                    <a href="/students/register" class="btn-primary">Add New Student</a>
                </div>
            </div>

            <!-- Class Selection and Quick Print Controls -->
            <div class="filter-bar" style="background: #f1f3f4; padding: 15px; border-radius: 6px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; gap: 15px; flex-wrap: wrap;">
                <form action="/students" method="GET" style="display: flex; align-items: center; gap: 10px;">
                    <label for="class-filter" style="margin: 0; font-weight: bold;">Filter by Class:</label>
                    <select name="class" id="class-filter" onchange="this.form.submit()" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 4px;">
                        <option value="">-- All Classes --</option>
                        <% classes.forEach(c => { %>
                            <option value="<%= c %>" <%= selectedClass === c ? 'selected' : '' %>><%= c %></option>
                        <% }) %>
                    </select>
                </form>

                <div style="display: flex; gap: 10px;">
                    <% if (selectedClass) { %>
                        <a href="/students/print?class=<%= selectedClass %>" target="_blank" class="btn-primary" style="background: #202124;">Print Class List (<%= selectedClass %>)</a>
                    <% } %>
                    <a href="/students/print" target="_blank" class="btn-primary" style="background: #1e8e3e;">Print All Students</a>
                </div>
            </div>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>Passport</th>
                        <th>Reg Number</th>
                        <th>Full Name</th>
                        <th>Class</th>
                        <th>Gender</th>
                        <th>Status</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (students.length === 0) { %>
                        <tr>
                            <td colspan="7" style="text-align: center;">No students found in this category.</td>
                        </tr>
                    <% } else { %>
                        <% students.forEach(student => { %>
                            <tr>
                                <td>
                                    <% if (student.passport_path) { %>
                                        <img src="<%= student.passport_path %>" alt="Passport" style="width: 45px; height: 45px; border-radius: 4px; object-fit: cover; border: 1px solid #ddd;">
                                    <% } else { %>
                                        <div style="width:45px; height:45px; background:#ddd; display:flex; align-items:center; justify-content:center; border-radius:4px; font-size:10px;">No Image</div>
                                    <% } %>
                                </td>
                                <td><%= student.reg_number %></td>
                                <td><%= student.fullname %></td>
                                <td><%= student.class %></td>
                                <td><%= student.gender %></td>
                                <td><span class="status-badge <%= student.status.toLowerCase() %>"><%= student.status %></span></td>
                                <td style="text-align: right; white-space: nowrap;">
                                    <a href="/students/edit/<%= student.id %>" class="btn-action edit" style="text-decoration:none; margin-right:5px; padding: 6px 12px; background: #e8f0fe; color: #1a73e8; border-radius:4px; font-size:12px; font-weight:bold;">Edit</a>
                                    <a href="/students/delete/<%= student.id %>" class="btn-action delete" onclick="return confirm('Are you sure you want to delete this student registration? This action is permanent.')" style="text-decoration:none; padding: 6px 12px; background: #fce8e6; color: #d93025; border-radius:4px; font-size:12px; font-weight:bold;">Delete</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </main>
    </div>
</body>
</html>
