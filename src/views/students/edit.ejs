<%- include('../partials/header') %>

<div class="container" style="padding: 30px 20px; max-width: 800px; margin: auto;">
  <div style="background: #ffffff; padding: 30px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); border-top: 5px solid #1a365d;">
    <h2 style="color: #1a365d; margin-top: 0; margin-bottom: 5px;">Edit Student Details</h2>
    <p style="color: #718096; font-size: 14px; margin-bottom: 25px;">Update student information, academic session, class, guardian contacts, or re-upload credentials.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div style="background: #fed7d7; color: #9b2c2c; padding: 12px; border-radius: 6px; margin-bottom: 20px;">
        <%= error %>
      </div>
    <% } %>

    <form action="/students/edit/<%= student.id %>" method="POST" enctype="multipart/form-data">
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Full Name *</label>
          <input type="text" name="full_name" value="<%= student.fullname || student.full_name || student.name || '' %>" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;" required>
        </div>

        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Academic Session *</label>
          <select name="session_year" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;" required>
            <% const currentSession = student.session_year || '2025/2026'; %>
            <option value="2025/2026" <%= currentSession === '2025/2026' ? 'selected' : '' %>>2025/2026</option>
            <option value="2026/2027" <%= currentSession === '2026/2027' ? 'selected' : '' %>>2026/2027</option>
            <option value="2027/2028" <%= currentSession === '2027/2028' ? 'selected' : '' %>>2027/2028</option>
          </select>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Class Category *</label>
          <% const currentClass = student.class || student.class_name || student.student_class || 'JSS 1'; %>
          <select name="class_name" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;" required>
            <option value="Pre-Nursery" <%= currentClass === 'Pre-Nursery' ? 'selected' : '' %>>Pre-Nursery</option>
            <option value="Nursery 1" <%= currentClass === 'Nursery 1' ? 'selected' : '' %>>Nursery 1</option>
            <option value="Nursery 2" <%= currentClass === 'Nursery 2' ? 'selected' : '' %>>Nursery 2</option>
            <option value="Primary 1" <%= currentClass === 'Primary 1' ? 'selected' : '' %>>Primary 1</option>
            <option value="Primary 2" <%= currentClass === 'Primary 2' ? 'selected' : '' %>>Primary 2</option>
            <option value="Primary 3" <%= currentClass === 'Primary 3' ? 'selected' : '' %>>Primary 3</option>
            <option value="Primary 4" <%= currentClass === 'Primary 4' ? 'selected' : '' %>>Primary 4</option>
            <option value="Primary 5" <%= currentClass === 'Primary 5' ? 'selected' : '' %>>Primary 5</option>
            <option value="JSS 1" <%= currentClass === 'JSS 1' ? 'selected' : '' %>>JSS 1</option>
            <option value="JSS 2" <%= currentClass === 'JSS 2' ? 'selected' : '' %>>JSS 2</option>
            <option value="JSS 3" <%= currentClass === 'JSS 3' ? 'selected' : '' %>>JSS 3</option>
          </select>
        </div>

        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Gender</label>
          <select name="gender" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;">
            <option value="Male" <%= student.gender === 'Male' ? 'selected' : '' %>>Male</option>
            <option value="Female" <%= student.gender === 'Female' ? 'selected' : '' %>>Female</option>
          </select>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Guardian Name</label>
          <input type="text" name="guardian_name" value="<%= student.guardian_name || '' %>" placeholder="Parent / Guardian Name" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;">
        </div>

        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Guardian Phone</label>
          <input type="text" name="guardian_phone" value="<%= student.guardian_phone || '' %>" placeholder="e.g. 08012345678" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;">
        </div>
      </div>

      <div style="margin-bottom: 20px;">
        <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Student Status</label>
        <select name="status" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;">
          <option value="Active" <%= (student.status || 'Active') === 'Active' ? 'selected' : '' %>>Active</option>
          <option value="Graduated" <%= student.status === 'Graduated' ? 'selected' : '' %>>Graduated</option>
          <option value="Transferred" <%= student.status === 'Transferred' ? 'selected' : '' %>>Transferred</option>
        </select>
      </div>

      <hr style="border: none; border-top: 1px solid #e2e8f0; margin: 25px 0;">
      <h3 style="color: #1a365d; font-size: 16px; margin-bottom: 15px;">Update Document Attachments & Passport</h3>

      <div style="margin-bottom: 15px;">
        <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Passport Photograph (Leave blank to keep current photo)</label>
        <input type="file" name="passport" accept="image/*" style="width: 100%; padding: 8px; border: 1px solid #cbd5e0; border-radius: 6px; background: #f7fafc;">
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 25px;">
        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Birth Certificate (Optional)</label>
          <input type="file" name="birth_certificate" accept="image/*,application/pdf" style="width: 100%; padding: 8px; border: 1px solid #cbd5e0; border-radius: 6px; background: #f7fafc;">
        </div>

        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Primary Testimonial / Cert (Optional)</label>
          <input type="file" name="primary_certificate" accept="image/*,application/pdf" style="width: 100%; padding: 8px; border: 1px solid #cbd5e0; border-radius: 6px; background: #f7fafc;">
        </div>
      </div>

      <button type="submit" style="width: 100%; background: #1a365d; color: white; padding: 12px; border: none; border-radius: 6px; font-weight: bold; font-size: 16px; cursor: pointer;">
        Save Changes
      </button>
      
      <div style="text-align: center; margin-top: 15px;">
        <a href="/students" style="color: #718096; text-decoration: none; font-size: 14px;">Cancel and return to directory</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
