<%- include('partials/header') %>

<div class="container" style="padding: 20px;">
  <h2>Welcome to Success Academy Jani Management System</h2>
  <div style="display: flex; gap: 20px; margin-top: 20px;">
    <div style="background: #1a365d; color: white; padding: 20px; border-radius: 8px; flex: 1;">
      <h3>Total Students</h3>
      <p style="font-size: 28px; font-weight: bold; margin: 5px 0;"><%= typeof studentCount !== 'undefined' ? studentCount : 0 %></p>
    </div>
    <div style="background: #d69e2e; color: white; padding: 20px; border-radius: 8px; flex: 1;">
      <h3>Total Staff</h3>
      <p style="font-size: 28px; font-weight: bold; margin: 5px 0;"><%= typeof teacherCount !== 'undefined' ? teacherCount : 0 %></p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
