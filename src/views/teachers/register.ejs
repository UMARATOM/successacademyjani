<%- include('../partials/header') %>

<div class="container" style="padding: 30px 20px; max-width: 700px; margin: auto;">
  <div style="background: #ffffff; padding: 30px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); border-top: 5px solid #2b6cb0;">
    <h2 style="color: #1a365d; margin-top: 0; margin-bottom: 5px;">Add New Staff Member</h2>
    <p style="color: #718096; font-size: 14px; margin-bottom: 25px;">Create a teacher account and set login credentials.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div style="background: #fed7d7; color: #9b2c2c; padding: 12px; border-radius: 6px; margin-bottom: 20px;">
        <%= error %>
      </div>
    <% } %>

    <form action="/teachers/register" method="POST">
      
      <div style="margin-bottom: 20px;">
        <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Staff Full Name *</label>
        <input type="text" name="fullname" placeholder="e.g. Mallam Kabir Sani" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;" required>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Username (For Login) *</label>
          <input type="text" name="username" placeholder="e.g. kabir2026" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;" required>
        </div>

        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Account Password *</label>
          <input type="password" name="password" placeholder="Set Password" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;" required>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 25px;">
        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Assigned Subject / Role</label>
          <input type="text" name="subject_assigned" placeholder="e.g. Mathematics Teacher" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;">
        </div>

        <div>
          <label style="display: block; font-weight: bold; color: #2d3748; margin-bottom: 6px;">Phone Number</label>
          <input type="text" name="phone" placeholder="e.g. 08030000000" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;">
        </div>
      </div>

      <button type="submit" style="width: 100%; background: #2b6cb0; color: white; padding: 12px; border: none; border-radius: 6px; font-weight: bold; font-size: 16px; cursor: pointer;">
        Create Staff Account
      </button>
      
      <div style="text-align: center; margin-top: 15px;">
        <a href="/teachers" style="color: #718096; text-decoration: none; font-size: 14px;">Cancel and return to staff list</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
