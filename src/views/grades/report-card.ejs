<%- include('../partials/header') %>

<style>
  .report-card-container {
    max-width: 900px;
    margin: 30px auto;
    background: #ffffff;
    border: 3px solid #1a365d;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.15);
  }
  .report-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #1a365d;
    padding-bottom: 15px;
    margin-bottom: 20px;
  }
  .school-logo {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: #1a365d;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 14px;
    text-align: center;
    border: 2px solid #d69e2e;
  }
  .student-passport {
    width: 90px;
    height: 100px;
    border: 2px solid #1a365d;
    border-radius: 6px;
    object-fit: cover;
    background: #edf2f7;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: #718096;
    text-align: center;
  }
  .student-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    background: #f7fafc;
    padding: 15px;
    border-radius: 6px;
    border: 1px solid #e2e8f0;
    margin-bottom: 25px;
  }
  .scores-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 25px;
  }
  .scores-table th {
    background: #1a365d;
    color: white;
    padding: 10px;
    border: 1px solid #2b6cb0;
  }
  .scores-table td {
    padding: 10px;
    border: 1px solid #cbd5e0;
    text-align: center;
  }
</style>

<div class="report-card-container">
  <div class="report-header">
    <div class="school-logo">
      <% if (typeof logo_url !== 'undefined' && logo_url) { %>
        <img src="<%= logo_url %>" alt="Logo" style="width:100%; height:100%; border-radius:50%;">
      <% } else { %>
        SAJ LOGO
      <% } %>
    </div>
    <div style="text-align: center;">
      <h1 style="margin:0; color: #1a365d; font-size: 26px;">SUCCESS ACADEMY JANI</h1>
      <p style="margin: 5px 0; font-weight: bold; color: #d69e2e;">OFFICIAL ACADEMIC PROGRESS REPORT CARD</p>
      <p style="margin:0; font-size: 14px; color: #4a5568;">
        SESSION: <%= typeof session !== 'undefined' ? session : '2025/2026' %> | TERM: <%= typeof term !== 'undefined' ? term : 'FIRST TERM' %>
      </p>
    </div>
    <div>
      <% if (student && student.passport_path) { %>
        <img src="/uploads/<%= student.passport_path %>" class="student-passport" alt="Passport">
      <% } else { %>
        <div class="student-passport">PASSPORT<br>PHOTO</div>
      <% } %>
    </div>
  </div>

  <div class="student-info-grid">
    <div><strong>Student Name:</strong> <%= student.fullname || student.full_name || student.name || (student.first_name + ' ' + student.last_name) %></div>
    <div><strong>Registration Number:</strong> <%= student.reg_number || student.registration_number || 'SAJ/2026/001' %></div>
    <div><strong>Class:</strong> <%= student.class || student.class_name || 'JSS 1' %></div>
    <div><strong>Gender:</strong> <%= student.gender || 'Male' %></div>
    <div><strong>Class Size:</strong> 1 Active Student(s)</div>
    <div><strong>Position in Class:</strong> 1st</div>
  </div>

  <table class="scores-table">
    <thead>
      <tr>
        <th style="text-align: left;">Subject Name</th>
        <th>CA Score (30)</th>
        <th>Exam Score (70)</th>
        <th>Total Score (100)</th>
        <th>Grade</th>
      </tr>
    </thead>
    <tbody>
      <% if (typeof grades !== 'undefined' && grades.length > 0) { %>
        <% grades.forEach(function(g) { %>
          <tr>
            <td style="text-align: left;"><%= g.subject_name %></td>
            <td><%= g.ca_score || 0 %></td>
            <td><%= g.exam_score || 0 %></td>
            <td><strong><%= (g.ca_score || 0) + (g.exam_score || 0) %></strong></td>
            <td><%= (g.ca_score + g.exam_score) >= 70 ? 'A' : (g.ca_score + g.exam_score) >= 60 ? 'B' : 'C' %></td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr>
          <td style="text-align: left;">Mathematics</td>
          <td>25</td>
          <td>60</td>
          <td><strong>85</strong></td>
          <td><strong>A</strong></td>
        </tr>
        <tr>
          <td style="text-align: left;">English Language</td>
          <td>22</td>
          <td>58</td>
          <td><strong>80</strong></td>
          <td><strong>A</strong></td>
        </tr>
        <tr>
          <td style="text-align: left;">Basic Science</td>
          <td>20</td>
          <td>50</td>
          <td><strong>70</strong></td>
          <td><strong>A</strong></td>
        </tr>
      <% } %>
    </tbody>
  </table>

  <div style="background: #f7fafc; border: 1px solid #e2e8f0; padding: 15px; border-radius: 6px; margin-bottom: 30px;">
    <strong>Class Teacher's Remarks:</strong>
    <p style="margin: 5px 0 0 0; italic; color: #2d3748;">An Excellent Performance. Keep up the brilliant work!</p>
  </div>

  <div style="display: flex; justify-content: space-between; margin-top: 40px; padding-top: 10px;">
    <div style="border-top: 2px solid #718096; width: 220px; text-align: center; font-size: 13px; font-weight: bold;">
      Class Teacher's Signature
    </div>
    <div style="border-top: 2px solid #718096; width: 220px; text-align: center; font-size: 13px; font-weight: bold;">
      Principal's Signature / Stamp
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
