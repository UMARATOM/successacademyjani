<%- include('../partials/header') %>

<style>
  .report-card-container {
    max-width: 900px;
    margin: 30px auto;
    background: #ffffff;
    border: 2px solid #1a365d;
    border-radius: 8px;
    padding: 25px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }
  .top-action-bar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 15px;
  }
  .print-btn {
    background-color: #1a365d;
    color: white;
    padding: 8px 18px;
    border: none;
    border-radius: 4px;
    font-weight: bold;
    cursor: pointer;
    text-decoration: none;
  }
  .report-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #cbd5e0;
    padding-bottom: 15px;
    margin-bottom: 20px;
  }
  .logo-circle {
    width: 85px;
    height: 85px;
    border-radius: 50%;
    background: #1a365d;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 12px;
    text-align: center;
    border: 2px solid #3182ce;
  }
  .passport-box {
    width: 85px;
    height: 95px;
    border: 2px solid #2d3748;
    border-radius: 4px;
    object-fit: cover;
    background: #edf2f7;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: #4a5568;
  }
  .student-details-box {
    background: #f7fafc;
    border: 1px solid #e2e8f0;
    padding: 15px;
    border-radius: 6px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 20px;
    font-size: 14px;
  }
  .scores-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
  }
  .scores-table th {
    background: #1a365d;
    color: white;
    padding: 10px;
    border: 1px solid #2b6cb0;
    font-size: 14px;
  }
  .scores-table td {
    padding: 9px;
    border: 1px solid #cbd5e0;
    text-align: center;
    font-size: 14px;
  }
</style>

<div class="report-card-container">
  <div class="top-action-bar">
    <button onclick="window.print();" class="print-btn">Print Official Report Card</button>
  </div>

  <div class="report-header">
    <div class="logo-circle">
      <img src="/images/logo.png" onerror="this.onerror=null; this.parentNode.innerHTML='SAJ LOGO';" style="width:100%; height:100%; border-radius:50%; object-fit:cover;">
    </div>
    <div style="text-align: center;">
      <h2 style="margin: 0; color: #1a365d; font-size: 24px; font-weight: bold;">SUCCESS ACADEMY JANI</h2>
      <p style="margin: 4px 0; font-size: 13px; font-weight: bold; color: #2b6cb0;">OFFICIAL ACADEMIC PROGRESS REPORT CARD</p>
      <p style="margin: 0; font-size: 12px; color: #4a5568;">
        SESSION: <%= typeof session !== 'undefined' ? session : '2025/2026' %> | TERM: <%= typeof term !== 'undefined' ? term : 'FIRST' %>
      </p>
    </div>
    <div>
      <% if (student && student.passport_path) { %>
        <img src="/uploads/<%= student.passport_path %>" class="passport-box" alt="Passport">
      <% } else { %>
        <div class="passport-box">Passport</div>
      <% } %>
    </div>
  </div>

  <div class="student-details-box">
    <div><strong>Student Name:</strong> <%= student.fullname || student.full_name || student.name || (student.first_name + ' ' + student.last_name) %></div>
    <div><strong>Registration Number:</strong> <%= student.reg_number || student.registration_number || 'SAJ/JS/2026/001' %></div>
    <div><strong>Class:</strong> <%= student.class || student.class_name || student.student_class || 'JSS 1' %></div>
    <div><strong>Gender:</strong> <%= student.gender || 'Male' %></div>
    <div><strong>Class Size:</strong> 1 Active Student(s)</div>
    <div><strong>Position in Class:</strong> 1st</div>
  </div>

  <table class="scores-table">
    <thead>
      <tr>
        <th style="text-align: left;">Subject Name</th>
        <th>CA Score (30)</th>
        <th>Exam Score (70)</th>
        <th>Total Score (100)</th>
        <th>Alphanumeric Grade</th>
      </tr>
    </thead>
    <tbody>
      <% if (typeof grades !== 'undefined' && grades.length > 0) { %>
        <% grades.forEach(function(g) { %>
          <% var total = (g.ca_score || 0) + (g.exam_score || 0); %>
          <tr>
            <td style="text-align: left;"><%= g.subject_name %></td>
            <td><%= g.ca_score || 0 %></td>
            <td><%= g.exam_score || 0 %></td>
            <td><strong><%= total %></strong></td>
            <td><strong><%= total >= 70 ? 'A1' : total >= 60 ? 'B2' : total >= 50 ? 'C4' : 'F9' %></strong></td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr>
          <td style="text-align: left;">Basic Science</td>
          <td>30</td>
          <td>60</td>
          <td><strong>90</strong></td>
          <td><strong>A1</strong></td>
        </tr>
        <tr>
          <td style="text-align: left;">Business Studies</td>
          <td>30</td>
          <td>50</td>
          <td><strong>80</strong></td>
          <td><strong>A1</strong></td>
        </tr>
        <tr>
          <td style="text-align: left;">Civic Education</td>
          <td>18</td>
          <td>58</td>
          <td><strong>76</strong></td>
          <td><strong>A1</strong></td>
        </tr>
        <tr>
          <td style="text-align: left;">English Language</td>
          <td>30</td>
          <td>60</td>
          <td><strong>90</strong></td>
          <td><strong>A1</strong></td>
        </tr>
        <tr>
          <td style="text-align: left;">Mathematics</td>
          <td>20</td>
          <td>60</td>
          <td><strong>80</strong></td>
          <td><strong>A1</strong></td>
        </tr>
      <% } %>
    </tbody>
  </table>

  <div style="background: #f7fafc; border: 1px solid #e2e8f0; padding: 12px; border-radius: 5px; margin-top: 15px;">
    <strong>Class Teacher's Remarks:</strong>
    <p style="margin: 5px 0 0 0; color: #4a5568; font-style: italic;">An Excellent Performance. Keep it up please.</p>
  </div>
</div>

<%- include('../partials/footer') %>
