<%- include('../partials/header') %>

<style>
  @media print {
    .navbar, .no-print { display: none !important; }
    body { background: white !important; padding: 0 !important; }
    .report-card-box { border: 2px solid #000 !important; box-shadow: none !important; margin: 0 !important; max-width: 100% !important; }
  }
</style>

<div class="container" style="padding: 20px; max-width: 900px; margin: auto;">
  
  <div class="no-print" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <a href="/students" style="color: #4a5568; text-decoration: none; font-weight: bold;">← Back to Students Directory</a>
    <button onclick="window.print();" style="padding: 10px 20px; background: #1a365d; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer;">
      🖨️ Print Report Card
    </button>
  </div>

  <div class="report-card-box" style="background: white; padding: 30px; border-radius: 10px; border: 3px double #1a365d; box-shadow: 0 4px 15px rgba(0,0,0,0.08);">
    
    <!-- Header -->
    <div style="text-align: center; border-bottom: 2px solid #1a365d; padding-bottom: 15px; margin-bottom: 20px;">
      <h1 style="margin: 0; color: #1a365d; font-size: 26px; letter-spacing: 1px;">SUCCESS ACADEMY JANI</h1>
      <p style="margin: 4px 0; font-weight: bold; color: #4a5568;">Katsina State, Nigeria</p>
      <h3 style="margin: 8px 0 0 0; background: #1a365d; color: white; display: inline-block; padding: 4px 16px; border-radius: 4px; font-size: 14px;">OFFICIAL STUDENT TERMINAL REPORT CARD</h3>
    </div>

    <!-- Student Metadata & Passport -->
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 25px; gap: 20px;">
      <div style="flex-grow: 1;">
        <table style="width: 100%; font-size: 14px; border-collapse: collapse;">
          <tr>
            <td style="padding: 5px 0; font-weight: bold; color: #4a5568;">Student Name:</td>
            <td style="padding: 5px 0; font-weight: bold; color: #1a365d;"><%= student.fullname || student.full_name || student.name %></td>
            <td style="padding: 5px 0; font-weight: bold; color: #4a5568;">Admission No:</td>
            <td style="padding: 5px 0; font-weight: bold; color: #2b6cb0;"><%= student.reg_number || student.registration_number || 'N/A' %></td>
          </tr>
          <tr>
            <td style="padding: 5px 0; font-weight: bold; color: #4a5568;">Class Category:</td>
            <td style="padding: 5px 0;"><%= student.class || student.class_name || 'JSS 1' %></td>
            <td style="padding: 5px 0; font-weight: bold; color: #4a5568;">Gender:</td>
            <td style="padding: 5px 0;"><%= student.gender || 'Male' %></td>
          </tr>
          <tr>
            <td style="padding: 5px 0; font-weight: bold; color: #4a5568;">Academic Session:</td>
            <td style="padding: 5px 0;"><%= session_year %></td>
            <td style="padding: 5px 0; font-weight: bold; color: #4a5568;">Term:</td>
            <td style="padding: 5px 0; font-weight: bold; color: #2b6cb0;"><%= term %></td>
          </tr>
        </table>
      </div>

      <div style="text-align: center; min-width: 90px;">
        <% if (student.passport_path) { %>
          <img src="<%= student.passport_path.startsWith('data:') ? student.passport_path : '/uploads/' + student.passport_path %>" style="width: 85px; height: 85px; object-fit: cover; border: 2px solid #1a365d; border-radius: 6px;">
        <% } else { %>
          <div style="width: 85px; height: 85px; border: 2px solid #cbd5e0; display: flex; align-items: center; justify-content: center; font-size: 11px; color: #718096; border-radius: 6px;">Passport</div>
        <% } %>
      </div>
    </div>

    <!-- Academic Subject Performance Table -->
    <table style="width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 25px;">
      <thead>
        <tr style="background: #1a365d; color: white;">
          <th style="border: 1px solid #1a365d; padding: 8px; text-align: left;">SUBJECT NAME</th>
          <th style="border: 1px solid #1a365d; padding: 8px; text-align: center;">1ST CA (20%)</th>
          <th style="border: 1px solid #1a365d; padding: 8px; text-align: center;">2ND CA (20%)</th>
          <th style="border: 1px solid #1a365d; padding: 8px; text-align: center;">EXAM (60%)</th>
          <th style="border: 1px solid #1a365d; padding: 8px; text-align: center;">TOTAL (100%)</th>
          <th style="border: 1px solid #1a365d; padding: 8px; text-align: center;">GRADE</th>
          <th style="border: 1px solid #1a365d; padding: 8px; text-align: center;">REMARKS</th>
        </tr>
      </thead>
      <tbody>
        <% if (grades && grades.length > 0) { %>
          <% grades.forEach(function(g) { %>
            <tr>
              <td style="border: 1px solid #cbd5e0; padding: 8px; font-weight: bold; color: #2d3748;"><%= g.subject_name %></td>
              <td style="border: 1px solid #cbd5e0; padding: 8px; text-align: center;"><%= g.ca1 %></td>
              <td style="border: 1px solid #cbd5e0; padding: 8px; text-align: center;"><%= g.ca2 %></td>
              <td style="border: 1px solid #cbd5e0; padding: 8px; text-align: center;"><%= g.exam %></td>
              <td style="border: 1px solid #cbd5e0; padding: 8px; text-align: center; font-weight: bold; color: #1a365d;"><%= g.total %></td>
              <td style="border: 1px solid #cbd5e0; padding: 8px; text-align: center; font-weight: bold;"><%= g.grade %></td>
              <td style="border: 1px solid #cbd5e0; padding: 8px; text-align: center; font-size: 11px; font-weight: bold;"><%= g.remarks %></td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="7" style="border: 1px solid #cbd5e0; padding: 15px; text-align: center; color: #718096;">No assessment records entered for this term yet.</td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <!-- Performance Summary -->
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-bottom: 25px; text-align: center;">
      <div style="border: 1px solid #cbd5e0; padding: 10px; border-radius: 6px; background: #f7fafc;">
        <span style="display: block; font-size: 11px; color: #718096; font-weight: bold;">TOTAL SUBJECTS</span>
        <strong style="font-size: 18px; color: #1a365d;"><%= subjectCount %></strong>
      </div>
      <div style="border: 1px solid #cbd5e0; padding: 10px; border-radius: 6px; background: #f7fafc;">
        <span style="display: block; font-size: 11px; color: #718096; font-weight: bold;">GRAND TOTAL SCORE</span>
        <strong style="font-size: 18px; color: #1a365d;"><%= grandTotal %></strong>
      </div>
      <div style="border: 1px solid #cbd5e0; padding: 10px; border-radius: 6px; background: #f7fafc;">
        <span style="display: block; font-size: 11px; color: #718096; font-weight: bold;">OVERALL AVERAGE</span>
        <strong style="font-size: 18px; color: #2b6cb0;"><%= overallAverage %>%</strong>
      </div>
    </div>

    <!-- Official Signatures & Remarks -->
    <div style="border-top: 1px solid #e2e8f0; padding-top: 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
      <div>
        <p style="margin: 0 0 5px 0; font-size: 12px; font-weight: bold; color: #4a5568;">Class Teacher's Remarks:</p>
        <p style="margin: 0; font-size: 13px; font-style: italic; color: #2d3748; border-bottom: 1px dotted #a0aec0; padding-bottom: 5px;">
          <%= overallAverage >= 50 ? 'Satisfactory academic performance. Keep working hard.' : 'Needs improvement in core subjects.' %>
        </p>
      </div>
      <div>
        <p style="margin: 0 0 5px 0; font-size: 12px; font-weight: bold; color: #4a5568;">Principal / Headmaster Signature:</p>
        <div style="border-bottom: 1px solid #a0aec0; height: 25px;"></div>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
