<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= student.first_name %> <%= student.last_name %> - Report Card</title>
  <style>
    body { font-family: Arial, sans-serif; background-color: #f5f5f5; padding: 20px; }
    .report-card { max-width: 800px; margin: 0 auto; background: #fff; padding: 30px; border: 2px solid #333; border-radius: 8px; }
    .header { display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid #333; padding-bottom: 15px; margin-bottom: 20px; }
    .logo-placeholder { width: 70px; height: 70px; border-radius: 50%; background: #0d47a1; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 11px; text-align: center; }
    .title-area { text-align: center; flex-grow: 1; }
    .title-area h1 { margin: 0; font-size: 24px; color: #0d47a1; }
    .title-area h3 { margin: 5px 0 0; font-size: 13px; letter-spacing: 1px; color: #444; }
    .student-info { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 20px; background: #f9f9f9; padding: 15px; border: 1px solid #ddd; border-radius: 6px; margin-bottom: 20px; font-size: 14px; }
    .student-info div span { font-weight: bold; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    th, td { border: 1px solid #333; padding: 8px 12px; text-align: center; font-size: 14px; }
    th { background-color: #e0e0e0; }
    .remarks-section { border: 1px solid #ddd; padding: 15px; border-radius: 6px; margin-bottom: 30px; }
    .signatures { display: flex; justify-content: space-between; margin-top: 40px; padding: 0 20px; }
    .signature-line { width: 200px; border-top: 1px solid #333; text-align: center; padding-top: 5px; font-size: 13px; font-weight: bold; }
    @media print { body { background: none; padding: 0; } .report-card { border: none; } }
  </style>
</head>
<body>

<div class="report-card">
  <div class="header">
    <div class="logo-placeholder">LOGO</div>
    <div class="title-area">
      <h1>SUCCESS ACADEMY JANI</h1>
      <h3>OFFICIAL ACADEMIC PROGRESS REPORT CARD</h3>
      <p style="margin: 4px 0 0 0; font-size: 12px; font-weight: bold;">
        SESSION: <%= typeof session !== 'undefined' ? session : '2025/2026' %> | TERM: <%= typeof term !== 'undefined' ? term : 'FIRST' %> TERM
      </p>
    </div>
    <div class="logo-placeholder">PASSPORT</div>
  </div>

  <div class="student-info">
    <div><span>Student Name:</span> <%= student.first_name %> <%= student.last_name %></div>
    <div><span>Registration Number:</span> <%= student.registration_number %></div>
    <div><span>Class:</span> <%= student.class_name %></div>
    <div><span>Gender:</span> <%= student.gender || 'Male' %></div>
    <div><span>Class Size:</span> <%= typeof class_size !== 'undefined' ? class_size : '1' %> Active Student(s)</div>
    <div><span>Cumulative Marks:</span> <%= typeof total_marks !== 'undefined' ? total_marks : '0' %></div>
    <div><span>Position in Class:</span> <%= typeof position !== 'undefined' ? position : '1st' %></div>
  </div>

  <table>
    <thead>
      <tr>
        <th style="text-align: left;">Subject Name</th>
        <th>CA Score (30)</th>
        <th>Exam Score (70)</th>
        <th>Total Score (100)</th>
        <th>Alphanumeric Grade</th>
      </tr>
    </thead>
    <tbody>
      <% if (typeof grades !== 'undefined') { %>
        <% grades.forEach(function(g) { %>
          <tr>
            <td style="text-align: left;"><%= g.subject_name %></td>
            <td><%= g.ca_score %></td>
            <td><%= g.exam_score %></td>
            <td><%= g.ca_score + g.exam_score %></td>
            <td>
              <% const total = g.ca_score + g.exam_score; %>
              <% if (total >= 75) { %> A1 <% } else if (total >= 70) { %> B2 <% } else if (total >= 65) { %> B3 <% } else if (total >= 60) { %> C4 <% } else if (total >= 55) { %> C5 <% } else if (total >= 50) { %> C6 <% } else if (total >= 45) { %> D7 <% } else if (total >= 40) { %> E8 <% } else { %> F9 <% } %>
            </td>
          </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>

  <div class="remarks-section">
    <h4 style="margin: 0 0 5px 0;">Class Teacher's Remarks:</h4>
    <p style="margin: 0;"><i><%= typeof remarks !== 'undefined' ? remarks : 'An Excellent Performance Keep it up please' %></i></p>
  </div>

  <div class="signatures">
    <div class="signature-line">Class Teacher's Signature</div>
    <div class="signature-line">Principal's Signature / Stamp</div>
  </div>
</div>

</body>
</html>
